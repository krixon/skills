#!/usr/bin/env python3
"""Entry point for the `worktree` command group.

Invoked by absolute path under ${CLAUDE_PLUGIN_ROOT}/bin/ (ADR 0008), not via
PATH. This stays thin: it puts the adapter package on the path and hands argv to
adapter.worktree.main, which holds the command logic. Future groups (bin/tracker,
bin/version) follow the same shape over the same bin/adapter substrate.
"""

import os
import sys

sys.path.insert(0, os.path.dirname(os.path.abspath(__file__)))

from adapter.worktree import main

if __name__ == "__main__":
    sys.exit(main())
