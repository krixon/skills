#!/usr/bin/env python3
"""Entry point for the `triage` command group.

Invoked by absolute path under ${CLAUDE_PLUGIN_ROOT}/bin/ (ADR 0008), not via
PATH. This stays thin: it puts the adapter package on the path, runs the
substrate preflight, and hands argv to adapter.triage.main, which holds the
present/act orchestration. triage only touches the tracker (gh) — it reads the
queue and a candidate, takes/releases the advisory claim, and applies the
state-machine label transitions — and owns no git isolation (its synthesis
evaluates an issue and drafts a brief, it writes no code), so it requires only
gh. Sibling of bin/capture over the same bin/adapter substrate.
"""

import os
import sys

sys.path.insert(0, os.path.dirname(os.path.abspath(__file__)))

from adapter.preflight import preflight
from adapter.triage import main

if __name__ == "__main__":
    rc = preflight(required=("gh",))
    if rc != 0:
        sys.exit(rc)
    sys.exit(main())
