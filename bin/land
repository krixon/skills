#!/usr/bin/env python3
"""Entry point for the `land` command group.

Invoked by absolute path under ${CLAUDE_PLUGIN_ROOT}/bin/ (ADR 0008), not via
PATH. This stays thin: it puts the adapter package on the path, runs the
substrate preflight, and hands argv to adapter.land.main, which holds the
orchestration. land drives BOTH git (worktree teardown, sync-main) and gh (the
merge mechanics), so it requires both. Sibling of bin/tracker and bin/worktree
over the same bin/adapter substrate.
"""

import os
import sys

sys.path.insert(0, os.path.dirname(os.path.abspath(__file__)))

from adapter.preflight import preflight
from adapter.land import main

if __name__ == "__main__":
    # land composes the worktree (git) and tracker (gh) mechanics, so it needs
    # both on PATH.
    rc = preflight(required=("git", "gh"))
    if rc != 0:
        sys.exit(rc)
    sys.exit(main())
