#!/usr/bin/env python3
"""Entry point for the `reap` command group.

Invoked by absolute path under ${CLAUDE_PLUGIN_ROOT}/bin/ (ADR 0008), not via
PATH. This stays thin: it puts the adapter package on the path, runs the
substrate preflight, and hands argv to adapter.reap.main, which holds the
orchestration. reap composes the worktree (git) and tracker (gh) mechanics —
the orphaned-worktree teardown and the claim/needs-info/epic reads and writes —
so it requires both. Sibling of bin/land over the same bin/adapter substrate.
"""

import os
import sys

sys.path.insert(0, os.path.dirname(os.path.abspath(__file__)))

from adapter.preflight import preflight
from adapter.reap import main

if __name__ == "__main__":
    rc = preflight(required=("git", "gh"))
    if rc != 0:
        sys.exit(rc)
    sys.exit(main())
